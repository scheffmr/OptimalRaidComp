			ORC_Toggle()
		</Binding>
		<Binding name="ORC_SUMMON">
			ORC_Summon()
		</Binding>
		<Binding name="ORC_ATTACK">
			ORC_Attack()
		</Binding>
		<Binding name="ORC_FOLLOW">
